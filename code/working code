#include <Servo.h>

Servo s1;
Servo s2;
Servo s3;
Servo s4;

char data;

void setup() {
  Serial.begin(9600);

  s1.attach(3);
  s2.attach(5);
  s3.attach(6);
  s4.attach(9);
}

void loop() {

  if (Serial.available()) {
    data = Serial.read();

    if (data == 'A') s1.write(0);
    if (data == 'B') s1.write(90);

    if (data == 'C') s2.write(45);
    if (data == 'D') s2.write(90);
  }
}
